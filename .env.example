# ══════════════════════════════════════════
# Cowork LABS — Mantenciones
# Environment Variables
# ══════════════════════════════════════════

# 1. Google Sheets API Key (from Google Cloud Console)
VITE_GOOGLE_API_KEY=

# 2. Google Sheet ID (from the URL of your sheet)
#    Example: if URL is https://docs.google.com/spreadsheets/d/1ABC123xyz/edit
#    then the ID is: 1ABC123xyz
VITE_GOOGLE_SHEET_ID=

# 3. Google Apps Script Web App URL (see SETUP_GUIDE.md step 3)
VITE_APPS_SCRIPT_URL=
